// ========== 交互小游戏系统 ==========

function createMiniGameOverlay(onSkip) {
  const overlay = document.createElement('div');
  overlay.className = 'mini-game-overlay';
  const panel = document.createElement('div');
  panel.className = 'mg-panel';
  overlay.appendChild(panel);
  document.getElementById('game').appendChild(overlay);
  // Skip button — injected after panel content is set
  overlay._onSkip = onSkip;
  overlay._addSkip = function() {
    if (!onSkip) return;
    const skipBtn = document.createElement('button');
    skipBtn.className = 'mg-skip-btn';
    skipBtn.textContent = '跳过';
    let skipped = false;
    skipBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (skipped) return;
      skipped = true;
      overlay.style.pointerEvents = 'none';
      overlay.style.transition = 'opacity 0.4s ease';
      overlay.style.opacity = '0';
      setTimeout(() => { overlay.remove(); onSkip(); }, 450);
    });
    panel.appendChild(skipBtn);
  };
  return { overlay, panel };
}

function removeMiniGame(overlay, delay) {
  setTimeout(() => {
    overlay.style.pointerEvents = 'none';
    overlay.style.transition = 'opacity 0.5s ease';
    overlay.style.opacity = '0';
    setTimeout(() => overlay.remove(), 550);
  }, delay || 0);
}


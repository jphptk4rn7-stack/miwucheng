// 防止小游戏回调重复触发的一次性包装器
function onceNav(fn) {
  let called = false;
  return function() {
    if (called) return;
    called = true;
    fn();
  };
}

// 重写 showAfterText 以支持小游戏
const _originalShowAfterText = showAfterText;
showAfterText = function() {
  const node = story[currentNode];
  if (node.miniGame) {
    const mg = node.miniGame;
    const triggerNode = currentNode;
    // 给玩家足够时间读完文字再弹出小游戏
    const readTime = Math.max(2000, node.text.length * 45);
    setTimeout(() => {
      // 如果玩家已经离开了这个节点，不再触发小游戏
      if (currentNode !== triggerNode) return;
      if (mg === 'puzzle') {
        const go = onceNav(() => goToNode(originalStreet1Next));
        startPuzzle(go, go);
      } else if (mg === 'codePuzzle') {
        const go = onceNav(() => goToNode(originalLab2Next));
        startCodePuzzle('0217', go, () => { applyStat({ reason: -5 }); go(); });
      } else if (mg === 'qte') {
        const go = onceNav(() => goToNode(originalTunnel1Next));
        startQTE(5, 8000, go, () => { applyStat({ courage: -5 }); go(); });
      } else if (mg === 'elevator') {
        const go = onceNav(() => goToNode(originalTower2Next));
        startElevatorHold(50, go, () => { applyStat({ courage: -3 }); go(); });
      } else if (mg === 'freqTune') {
        const go = onceNav(() => goToNode(originalMemory1Next));
        startFreqTune(961, go, () => { applyStat({ bond: -3 }); go(); });
      } else if (mg === 'hackType') {
        const go = onceNav(() => goToNode(originalTruth1Next));
        startHackTyping(['override', 'access', 'root'], go, () => { applyStat({ reason: -5 }); go(); });
      } else if (mg === 'doorMash') {
        const go = onceNav(() => goToNode(originalEscape1Next));
        startDoorMash(30, 8000, go, () => { applyStat({ courage: -3 }); go(); });
      }
    }, readTime);
    return;
  }
  _originalShowAfterText();
};


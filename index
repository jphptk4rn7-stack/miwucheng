// ========== 视频与BGM ==========
const videoA = document.getElementById('scene-video-a');
const videoB = document.getElementById('scene-video-b');
const bgmAudio = document.getElementById('bgm');
const noVideoHint = document.getElementById('no-video-hint');
let videoQueue = [];
let videoPlaying = false;
let activeVideo = videoA;
let standbyVideo = videoB;
let lastSceneForVideo = null;
let videoGeneration = 0; // 每次 playNodeVideo 递增，用于作废旧回调

function resetVideo(v) {
  v.onloadeddata = null;
  v.onended = null;
  v.pause();
  v.classList.remove('active', 'fade-in', 'fade-out');
  v.style.opacity = '';
  v.removeAttribute('src');
  v.load();
}

function swapVideos() {
  const tmp = activeVideo;
  activeVideo = standbyVideo;
  standbyVideo = tmp;
}

function playNodeVideo(videoIds, sceneKey) {
  noVideoHint.classList.remove('active');
  const isSceneChange = lastSceneForVideo != null && lastSceneForVideo !== sceneKey;
  lastSceneForVideo = sceneKey;

  // 递增 generation，让所有旧的异步回调失效
  const gen = ++videoGeneration;

  videoA.onloadeddata = null;
  videoA.onended = null;
  videoB.onloadeddata = null;
  videoB.onended = null;

  if (!videoIds || videoIds.length === 0) {
    if (isSceneChange) {
      activeVideo.classList.add('fade-out');
      activeVideo.style.opacity = '0';
      setTimeout(() => {
        if (videoGeneration !== gen) return;
        resetVideo(activeVideo); resetVideo(standbyVideo);
      }, 350);
    } else {
      resetVideo(activeVideo);
      resetVideo(standbyVideo);
    }
    videoPlaying = false;
    noVideoHint.classList.add('active');
    return;
  }

  videoQueue = [...videoIds];
  videoPlaying = true;

  if (isSceneChange) {
    activeVideo.classList.add('fade-out');
    activeVideo.style.opacity = '0';
    setTimeout(() => {
      if (videoGeneration !== gen) return;
      resetVideo(activeVideo);
      loadAndPlay(true, gen);
    }, 320);
  } else {
    loadAndPlay(false, gen);
  }
}

function loadAndPlay(useFade, gen) {
  if (videoGeneration !== gen) return;
  if (videoQueue.length === 0) { videoPlaying = false; return; }
  const id = videoQueue.shift();
  const hasOldVideo = activeVideo.classList.contains('active');

  if (!hasOldVideo) {
    activeVideo.src = './' + id + '.mp4';
    activeVideo.currentTime = 0;
    if (useFade) {
      activeVideo.style.opacity = '0';
      activeVideo.classList.add('active', 'fade-in');
      activeVideo.onloadeddata = () => {
        activeVideo.onloadeddata = null;
        if (videoGeneration !== gen) return;
        activeVideo.play().catch(() => {});
        activeVideo.style.opacity = '1';
        setTimeout(() => activeVideo.classList.remove('fade-in'), 450);
      };
    } else {
      activeVideo.style.opacity = '1';
      activeVideo.classList.add('active');
      activeVideo.onloadeddata = () => {
        activeVideo.onloadeddata = null;
        if (videoGeneration !== gen) return;
        activeVideo.play().catch(() => {});
      };
    }
    activeVideo.load();
    activeVideo.onended = () => {
      if (videoGeneration !== gen) return;
      if (videoQueue.length > 0) loadAndPlay(false, gen);
      else videoPlaying = false;
    };
  } else {
    const sb = standbyVideo; // 捕获当前 standby 引用
    sb.src = './' + id + '.mp4';
    sb.currentTime = 0;
    sb.style.opacity = '0';
    sb.classList.remove('active', 'fade-in', 'fade-out');

    sb.onloadeddata = () => {
      sb.onloadeddata = null;
      if (videoGeneration !== gen) return;
      sb.style.opacity = '1';
      sb.classList.add('active');
      sb.play().catch(() => {});
      activeVideo.onended = null;
      activeVideo.classList.remove('active');
      activeVideo.pause();
      activeVideo.style.opacity = '0';
      swapVideos();
      activeVideo.onended = () => {
        if (videoGeneration !== gen) return;
        if (videoQueue.length > 0) loadAndPlay(false, gen);
        else videoPlaying = false;
      };
      setTimeout(() => { if (videoGeneration === gen) resetVideo(standbyVideo); }, 100);
    };
    sb.load();

    // 超时保底
    setTimeout(() => {
      if (videoGeneration !== gen) return;
      if (sb.src && !sb.classList.contains('active')) {
        sb.onloadeddata = null;
        sb.style.opacity = '1';
        sb.classList.add('active');
        sb.play().catch(() => {});
        activeVideo.onended = null;
        activeVideo.classList.remove('active');
        activeVideo.pause();
        activeVideo.style.opacity = '0';
        swapVideos();
        activeVideo.onended = () => {
          if (videoGeneration !== gen) return;
          if (videoQueue.length > 0) loadAndPlay(false, gen);
          else videoPlaying = false;
        };
        setTimeout(() => { if (videoGeneration === gen) resetVideo(standbyVideo); }, 100);
      }
    }, 500);
  }
}

function startBGM() {
  bgmAudio.volume = 0.3;
  bgmAudio.play().catch(() => {
    const resume = () => {
      bgmAudio.play().catch(() => {});
      document.removeEventListener('click', resume);
    };
    document.addEventListener('click', resume);
  });
}

function goToNode(nodeId) {
  currentNode = nodeId;
  const node = story[nodeId];
  if (!node) return;
  nodeHistory.push({ id: nodeId, scene: node.scene, speaker: node.speaker || '', text: node.text });
  recordVisited(nodeId);
  // 隐藏素材暂缺提示（playNodeVideo会按需重新显示）
  noVideoHint.classList.remove('active');
  setScene(node.scene);
  playNodeVideo(node.video, node.scene);
  speakerEl.textContent = node.speaker || '';
  if (node.stat) applyStat(node.stat);
  typeText(node.text, showAfterText, nodeId);
}

document.getElementById('game').addEventListener('click', () => {
  if (isTyping) { skipType(); return; }
  const node = story[currentNode];
  if (node && node.next && !node.choices && !node.ending) goToNode(node.next);
});

document.getElementById('start-btn').addEventListener('click', () => {
  titleScreen.classList.add('fade-out');
  startBGM();
  setTimeout(() => {
    titleScreen.style.display = 'none';
    dialogBox.style.display = 'block';
    statusPanel.style.display = 'block';
    document.getElementById('menu-btn').style.display = 'flex';
    updateStatUI();
    // 先触发迷雾擦除交互，完成后再进入剧情
    startFogWipe(35, () => goToNode('wake_1'), () => goToNode('wake_1'));
  }, 1500);
});

document.getElementById('restart-btn').addEventListener('click', () => {
  endingScreen.style.opacity = '0';
  setTimeout(() => {
    endingScreen.style.display = 'none';
    choiceCount = 0;
    stats = { courage: 50, reason: 50, bond: 50 };
    nodeHistory = [];

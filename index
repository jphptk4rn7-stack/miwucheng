<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<title>迷雾城 - 互动影游</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  html, body {
    background: #000;
    color: #e0e0e0;
    font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
    height: 100%; width: 100%;
    overflow: hidden;
    touch-action: manipulation;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  #game {
    position: relative;
    /* 竖版9:16比例，高度撑满，宽度按比例计算 */
    height: 100%;
    width: min(100%, 56.25vh); /* 9/16 = 0.5625 */
    max-width: 100%;
    display: flex; flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    overflow: hidden;
    background: #0a0a0f;
  }
  #scene-bg {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100%;
    background-size: cover;
    background-position: center;
    transition: opacity 1.2s ease;
    z-index: 0;
  }
  #fog {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100%;
    background: radial-gradient(ellipse at 50% 40%, transparent 20%, rgba(10,10,15,0.88) 100%);
    z-index: 1; pointer-events: none;
  }
  #particles {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 2; pointer-events: none;
  }

  /* ========== 数值面板 ========== */
  #status-panel {
    position: absolute; top: 0; left: 0; right: 0;
    z-index: 20;
    padding: 12px 16px;
    padding-top: max(12px, env(safe-area-inset-top));
    background: linear-gradient(180deg, rgba(5,5,12,0.85) 0%, transparent 100%);
    display: none;
  }
  #status-header {
    margin-bottom: 8px;
  }
  #chapter-name {
    font-size: 13px; color: rgba(170,190,235,0.75);
    letter-spacing: 3px;
    text-align: center;
  }
  #stat-bars {
    display: flex; gap: 10px; justify-content: center;
  }
  .stat-item {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    flex: 1; max-width: 110px;
  }
  .stat-label {
    font-size: 11px; letter-spacing: 2px;
    display: flex; align-items: center; gap: 4px;
  }
  .stat-icon { font-size: 13px; }
  .stat-bar-bg {
    width: 100%; height: 5px;
    background: rgba(255,255,255,0.12);
    border-radius: 3px; overflow: hidden;
  }
  .stat-bar-fill {
    height: 100%; border-radius: 3px;
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .stat-value {
    font-size: 11px; font-variant-numeric: tabular-nums;
  }
  .stat-courage .stat-label { color: #ff8a65; }
  .stat-courage .stat-bar-fill { background: linear-gradient(90deg, #ff6b35, #ff8a65); }
  .stat-courage .stat-value { color: #ff8a65; }
  .stat-reason .stat-label { color: #64b5f6; }
  .stat-reason .stat-bar-fill { background: linear-gradient(90deg, #1e88e5, #64b5f6); }
  .stat-reason .stat-value { color: #64b5f6; }
  .stat-bond .stat-label { color: #ce93d8; }
  .stat-bond .stat-bar-fill { background: linear-gradient(90deg, #9c27b0, #ce93d8); }
  .stat-bond .stat-value { color: #ce93d8; }

  .stat-change {
    position: absolute; z-index: 50;
    font-size: 14px; font-weight: bold;
    pointer-events: none;
    animation: statFloat 1.2s ease-out forwards;
  }
  @keyframes statFloat {
    0% { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(-30px); }
  }

  /* ========== 对话框 ========== */
  #dialog-box {
    position: relative; z-index: 10;
    width: calc(100% - 24px);
    max-width: 500px;
    background: linear-gradient(180deg, rgba(15,15,25,0.93) 0%, rgba(10,10,18,0.97) 100%);
    border: 1px solid rgba(100,140,255,0.15);
    border-radius: 16px;
    padding: 20px;
    margin-bottom: max(20px, env(safe-area-inset-bottom));
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 -4px 40px rgba(60,100,200,0.1);
  }
  #speaker {
    font-size: 14px; color: #7eaaff;
    margin-bottom: 8px; letter-spacing: 2px;
    font-weight: 500;
  }
  #text {
    font-size: 16px; line-height: 1.9;
    min-height: 50px;
    color: #e2e8f4;
  }
  #text .cursor {
    display: inline-block; width: 2px; height: 15px;
    background: #6a9fff; margin-left: 2px;
    animation: blink 0.8s infinite;
    vertical-align: text-bottom;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  #choices {
    display: flex; flex-direction: column; gap: 8px;
    margin-top: 16px;
  }
  .choice-btn {
    background: rgba(60,100,200,0.08);
    border: 1px solid rgba(100,140,255,0.25);
    border-radius: 10px;
    padding: 13px 16px;
    color: #c8d8ff;
    font-size: 15px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: left;
    display: flex; flex-direction: column; gap: 4px;
  }
  .choice-btn:active {
    background: rgba(60,100,200,0.25);
    border-color: rgba(100,160,255,0.7);
    color: #fff;
    transform: scale(0.98);
  }
  .choice-stat-hint {
    font-size: 12px; opacity: 0.6;
    display: flex; gap: 8px;
  }
  .hint-up { color: #81c784; }
  .hint-down { color: #ef5350; }

  #continue-hint {
    text-align: center; margin-top: 12px;
    font-size: 13px; color: rgba(160,180,225,0.55);
    animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%,100%{opacity:0.3} 50%{opacity:0.7} }

  /* ========== 标题画面 ========== */
  #title-screen {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 100;
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    background: radial-gradient(ellipse at 50% 40%, #0f1020 0%, #060610 100%);
    transition: opacity 1.5s ease;
    overflow: hidden;
  }
  #title-screen::before {
    content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background:
      radial-gradient(circle at 20% 80%, rgba(40,60,180,0.08) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(60,40,160,0.06) 0%, transparent 50%),
      radial-gradient(circle at 50% 50%, rgba(30,50,120,0.1) 0%, transparent 70%);
    animation: titleAmbient 8s ease-in-out infinite alternate;
  }
  @keyframes titleAmbient {
    0% { opacity: 0.6; transform: scale(1); }
    100% { opacity: 1; transform: scale(1.1); }
  }
  /* 扫光线 */
  #title-screen::after {
    content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(100,140,255,0.03), rgba(100,140,255,0.06), rgba(100,140,255,0.03), transparent);
    animation: titleSweep 6s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes titleSweep {
    0% { left: -50%; }
    100% { left: 150%; }
  }
  #title-screen h1 {
    font-size: 44px; color: #c0d0ff;
    text-shadow: 0 0 60px rgba(80,120,255,0.5), 0 0 120px rgba(60,100,255,0.2);
    letter-spacing: 12px; margin-bottom: 8px;
    animation: titleGlowIn 1s ease-out forwards, titleFloat 4s ease-in-out 1s infinite;
    opacity: 0; position: relative;
  }
  @keyframes titleGlowIn {
    0% { opacity: 0; transform: translateY(20px) scale(0.95); filter: blur(8px); letter-spacing: 30px; }
    60% { opacity: 1; filter: blur(0); }
    100% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); letter-spacing: 12px; }
  }
  @keyframes titleFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }
  /* 标题故障闪烁 */
  #title-screen h1::before {
    content: '迷 雾 城'; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    color: rgba(255,60,80,0.4); z-index: -1;
    animation: titleGlitch 5s ease-in-out infinite;
    clip-path: inset(0 0 0 0);
  }
  @keyframes titleGlitch {
    0%, 92%, 100% { transform: translate(0); clip-path: inset(0 0 0 0); opacity: 0; }
    93% { transform: translate(-2px, 1px); clip-path: inset(20% 0 60% 0); opacity: 1; }
    94% { transform: translate(2px, -1px); clip-path: inset(50% 0 20% 0); opacity: 1; }
    95% { transform: translate(0); clip-path: inset(0 0 0 0); opacity: 0; }
    96% { transform: translate(1px, 2px); clip-path: inset(30% 0 40% 0); opacity: 0.6; }
    97% { transform: translate(0); opacity: 0; }
  }
  #title-screen .subtitle {
    font-size: 14px; color: rgba(170,190,230,0.6);
    letter-spacing: 4px; margin-bottom: 40px;
    animation: subtitleIn 1s ease-out 0.3s forwards;
    opacity: 0;
  }
  @keyframes subtitleIn {
    0% { opacity: 0; letter-spacing: 12px; }
    100% { opacity: 0.6; letter-spacing: 4px; }
  }
  #title-screen .tagline {
    font-size: 14px; color: rgba(180,195,225,0.5);
    letter-spacing: 2px; margin-bottom: 50px;
    max-width: 280px; text-align: center; line-height: 1.8;
    animation: taglineIn 0.8s ease-out 0.6s forwards;
    opacity: 0;
  }
  @keyframes taglineIn {
    0% { opacity: 0; transform: translateY(10px); }
    100% { opacity: 0.5; transform: translateY(0); }
  }
  #title-screen .title-code {
    position: absolute; top: 12%; left: 50%; transform: translateX(-50%);
    font-size: 11px; color: rgba(100,140,255,0.15);
    letter-spacing: 3px; font-family: monospace;
    animation: codeFlicker 3s ease-in-out 0.8s infinite;
    opacity: 0;
  }
  @keyframes codeFlicker {
    0%, 100% { opacity: 0.15; }
    50% { opacity: 0.3; }
    75% { opacity: 0.1; }
  }
  #title-screen .title-particles {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none; overflow: hidden;
  }
  #title-screen .title-particles .tp {
    position: absolute; border-radius: 50%;
    background: rgba(100,150,255,0.3);
    animation: tpFloat linear infinite;
  }
  @keyframes tpFloat {
    0% { transform: translateY(0) scale(1); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(-100vh) scale(0.3); opacity: 0; }
  }
  #start-btn {
    background: transparent;
    border: 1px solid rgba(100,140,255,0.35);
    border-radius: 28px;
    padding: 14px 44px;
    color: #8ab4ff;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.4s ease;
    letter-spacing: 4px;
    animation: btnIn 0.6s ease-out 0.9s forwards, btnPulse 3s ease-in-out 1.5s infinite;
    opacity: 0;
    position: relative;
    overflow: hidden;
  }
  @keyframes btnIn {
    0% { opacity: 0; transform: translateY(15px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  @keyframes btnPulse {
    0%, 100% { box-shadow: 0 0 15px rgba(80,120,255,0.1), inset 0 0 15px rgba(80,120,255,0.05); }
    50% { box-shadow: 0 0 25px rgba(80,120,255,0.25), inset 0 0 25px rgba(80,120,255,0.1); border-color: rgba(100,160,255,0.6); }
  }
  #start-btn::after {
    content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
    animation: btnShine 4s ease-in-out 3s infinite;
  }
  @keyframes btnShine {
    0% { left: -100%; }
    50% { left: 100%; }
    100% { left: 100%; }
  }
  #start-btn:active {
    background: rgba(60,100,200,0.2);
    border-color: rgba(100,160,255,0.8);
    color: #fff;
  }

  /* ========== 结局画面 ========== */
  #ending-screen {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 100;
    display: none; flex-direction: column;
    justify-content: center; align-items: center;
    background: radial-gradient(ellipse at 50% 40%, #0f1020 0%, #060610 100%);
    padding: 30px;
  }
  #ending-screen .ending-label {
    font-size: 14px; color: rgba(170,190,230,0.55);
    letter-spacing: 6px; margin-bottom: 14px;
  }
  #ending-screen h1 {
    font-size: 32px; color: #c0d0ff;
    text-shadow: 0 0 40px rgba(80,120,255,0.4);
    letter-spacing: 6px; margin-bottom: 16px;
    text-align: center;
  }
  #ending-screen .ending-desc {
    font-size: 15px; color: rgba(200,212,240,0.75);
    max-width: 340px; text-align: center;
    line-height: 1.9; margin-bottom: 24px;
  }
  #ending-stats {
    display: flex; gap: 20px; margin-bottom: 32px;
  }
  .ending-stat {
    text-align: center;
  }
  .ending-stat-val {
    font-size: 24px; font-weight: bold;
  }
  .ending-stat-label {
    font-size: 11px; letter-spacing: 2px;
    opacity: 0.6; margin-top: 2px;
  }
  #restart-btn {
    background: transparent;
    border: 1px solid rgba(100,140,255,0.35);
    border-radius: 28px;
    padding: 12px 36px;
    color: #8ab4ff; font-size: 14px;
    cursor: pointer; transition: all 0.4s ease;
    letter-spacing: 3px;
  }
  #restart-btn:active {
    background: rgba(60,100,200,0.2);
    border-color: rgba(100,160,255,0.8);
    color: #fff;
  }

  .fade-out { opacity: 0 !important; pointer-events: none !important; }

  /* ========== 菜单按钮 ========== */
  #menu-btn {
    position: absolute; top: max(14px, env(safe-area-inset-top)); right: 14px;
    z-index: 25;
    background: rgba(10,12,25,0.55);
    border: 1px solid rgba(130,170,255,0.15);
    border-radius: 50%; width: 36px; height: 36px;
    color: rgba(160,196,255,0.55); font-size: 16px; line-height: 1;
    cursor: pointer; transition: all 0.3s ease;
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    display: none; align-items: center; justify-content: center;
  }
  #menu-btn:active { background: rgba(60,100,200,0.35); color: #fff; }

  /* ========== 转场遮罩 ========== */
  #transition-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    z-index: 80; pointer-events: none; opacity: 0;
    background: #0a0a0f;
    transition: opacity 0.5s ease;
  }

  /* ========== 素材暂缺提示 ========== */
  #no-video-hint {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    z-index: 3; display: none;
    justify-content: center; align-items: center;
    background: radial-gradient(ellipse at 50% 40%, rgba(15,16,30,0.95) 0%, rgba(6,6,16,0.98) 100%);
  }
  #no-video-hint.active { display: flex; }
  .no-video-content {
    text-align: center; animation: noVideoFadeIn 0.8s ease;
  }
  .no-video-icon {
    font-size: 36px; margin-bottom: 12px; opacity: 0.3;
    animation: noVideoPulse 3s ease-in-out infinite;
  }
  .no-video-text {
    font-size: 14px; color: rgba(160,180,220,0.45);
    letter-spacing: 3px;
  }
  @keyframes noVideoFadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes noVideoPulse { 0%,100% { opacity: 0.2; } 50% { opacity: 0.4; } }

  /* ========== 菜单遮罩 + 面板 ========== */
  #menu-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    z-index: 200; display: none;
    background: rgba(2,2,8,0.85);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    justify-content: center; align-items: center;
  }
  #menu-overlay.open { display: flex; }
  #menu-panel {
    background: linear-gradient(180deg, #1a1a30 0%, #131322 100%);
    border: 1px solid rgba(120,160,255,0.25);
    border-radius: 16px; padding: 30px 26px;
    width: calc(100% - 40px); max-width: 420px;
    max-height: 80vh; overflow-y: auto;
    position: relative;
    box-shadow: 0 8px 40px rgba(0,0,0,0.5);
  }
  #menu-panel::-webkit-scrollbar { width: 4px; }
  #menu-panel::-webkit-scrollbar-thumb { background: rgba(120,160,255,0.3); border-radius: 2px; }
  #menu-title {
    text-align: center; font-size: 18px; color: #c0d4f0;
    letter-spacing: 5px; margin-bottom: 22px;
  }
  #menu-close {
    position: absolute; top: 14px; right: 16px;
    background: none; border: none; color: #8898c0;
    font-size: 26px; cursor: pointer; line-height: 1;
  }
  #menu-close:active { color: #a0c4ff; }
  .menu-option {
    display: flex; align-items: center; gap: 12px;
    background: rgba(70,110,210,0.1);
    border: 1px solid rgba(120,160,255,0.28);
    border-radius: 12px; padding: 16px 20px;
    color: #dce4f8; font-size: 16px;
    cursor: pointer; transition: all 0.3s ease;
    margin-bottom: 10px; width: 100%;
  }
  .menu-option:active {
    background: rgba(70,110,210,0.25);
    border-color: rgba(120,170,255,0.6);
    color: #fff;
  }
  .menu-option-icon { font-size: 20px; opacity: 0.9; }

  /* ========== 存档/读档子面板 ========== */
  #menu-main, #menu-save, #menu-load, #menu-log { display: none; }
  #menu-main.active, #menu-save.active, #menu-load.active, #menu-log.active { display: block; }
  .menu-back {
    background: none; border: none; color: #8898c0;
    font-size: 14px; cursor: pointer; margin-bottom: 16px;
    display: flex; align-items: center; gap: 5px;
  }
  .menu-back:active { color: #a0c4ff; }
  .sub-title {
    text-align: center; font-size: 16px; color: #b0c0e0;
    letter-spacing: 4px; margin-bottom: 18px;
  }
  .save-slot {
    background: rgba(70,110,210,0.08);
    border: 1px solid rgba(120,160,255,0.22);
    border-radius: 12px; padding: 16px;
    margin-bottom: 10px; cursor: pointer;
    transition: all 0.3s ease;
  }
  .save-slot:active { background: rgba(70,110,210,0.22); border-color: rgba(120,170,255,0.5); }
  .save-slot.empty { opacity: 0.5; }
  .save-slot-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 8px;
  }
  .save-slot-label { font-size: 15px; color: #a0c4ff; letter-spacing: 1px; font-weight: 500; }
  .save-slot-time { font-size: 13px; color: #8090b8; }
  .save-slot-info { font-size: 14px; color: #b8c8e8; }
  .save-slot-stats {
    display: flex; gap: 12px; margin-top: 8px; font-size: 13px;
  }
  .save-slot-stats span:nth-child(1) { color: #ffab91; }
  .save-slot-stats span:nth-child(2) { color: #90caf9; }
  .save-slot-stats span:nth-child(3) { color: #e1bee7; }
  .slot-disabled { pointer-events: none; opacity: 0.35; }

  /* ========== 剧情回顾 ========== */
  .log-list { max-height: 55vh; overflow-y: auto; padding-right: 4px; }
  .log-list::-webkit-scrollbar { width: 4px; }
  .log-list::-webkit-scrollbar-thumb { background: rgba(120,160,255,0.3); border-radius: 2px; }
  .log-chapter-divider {
    font-size: 12px; color: #8898c0; letter-spacing: 3px;
    text-align: center; padding: 12px 0 8px;
    margin-top: 8px; margin-bottom: 4px;
    border-top: 1px solid rgba(120,160,255,0.15);
  }
  .log-chapter-divider:first-child { border-top: none; margin-top: 0; }
  .log-item {
    border-left: 2px solid rgba(120,160,255,0.3);
    padding: 6px 0 6px 14px; margin-bottom: 4px;
  }
  .log-speaker { font-size: 13px; color: #a0c4ff; margin-top: 4px; font-weight: 500; }
  .log-text { font-size: 15px; color: #c8d4ec; line-height: 1.8; margin-top: 4px; }
  .log-empty { text-align: center; color: #8090b8; font-size: 15px; padding: 30px 0; }

  /* ========== 关键词高亮 ========== */
  .kw { color: #e8b84b; font-weight: 600; text-shadow: 0 0 8px rgba(232,184,75,0.25); }

  /* ========== 剧情分支图 ========== */
  #flowchart-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    z-index: 200; display: none;
    background: rgba(4,4,12,0.96);
    backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    justify-content: center; align-items: center;
  }
  #flowchart-overlay.open { display: flex; }
  #flowchart-panel {
    background: radial-gradient(ellipse at 50% 0%, rgba(25,30,55,0.98) 0%, rgba(10,10,18,0.99) 100%);
    border: 1px solid rgba(100,140,240,0.2);
    border-radius: 20px; padding: 28px 16px 24px;
    width: calc(100% - 20px); max-width: 600px;
    max-height: 90vh; overflow: auto;
    position: relative;
    box-shadow: 0 20px 80px rgba(0,0,0,0.7), inset 0 1px 0 rgba(120,160,255,0.08);
  }
  #flowchart-panel::-webkit-scrollbar { width: 3px; }
  #flowchart-panel::-webkit-scrollbar-thumb { background: rgba(100,140,255,0.25); border-radius: 2px; }
  .flowchart-title {
    text-align: center; font-size: 16px; color: rgba(200,215,250,0.8);
    letter-spacing: 6px; margin-bottom: 22px; font-weight: 500;
  }
  #flowchart-close {
    position: absolute; top: 12px; right: 14px;
    background: none; border: none; color: rgba(160,180,220,0.6);
    font-size: 26px; cursor: pointer; line-height: 1;
  }
  #flowchart-close:active { color: #a0c4ff; }
  #flowchart-tree {
    position: relative; width: 100%;
  }
  #flowchart-tree svg {
    position: absolute; top: 0; left: 0;
    pointer-events: none; overflow: visible;
  }
  .fc-node {
    position: absolute; transform: translateX(-50%);
    padding: 8px 16px; border-radius: 10px;
    font-size: 13px; letter-spacing: 1.5px;
    text-align: center; cursor: default;
    border: 1px solid rgba(60,80,140,0.3);
    background: rgba(20,24,45,0.85);
    color: rgba(120,135,180,0.5);
    transition: all 0.3s ease;
    white-space: nowrap;
    z-index: 1;
    font-weight: 500;
  }
  .fc-node--completed {
    background: rgba(30,42,80,0.92);
    border-color: rgba(90,140,250,0.55);
    color: #b8d0f5;
    cursor: pointer;
    box-shadow: 0 0 16px rgba(60,110,240,0.15);
  }
  .fc-node--completed:active {
    background: rgba(40,55,110,0.95);
    border-color: rgba(110,170,255,0.85);
    color: #fff;
  }
  .fc-node--current {
    background: linear-gradient(135deg, rgba(35,55,110,0.95) 0%, rgba(45,65,130,0.95) 100%);
    border-color: rgba(100,165,255,0.75);
    color: #e0ecff;
    cursor: pointer;
    box-shadow: 0 0 24px rgba(60,120,255,0.25);
    animation: fcPulse 3s ease-in-out infinite;
  }
  @keyframes fcPulse {
    0%,100% { box-shadow: 0 0 24px rgba(60,120,255,0.25); border-color: rgba(100,165,255,0.75); }
    50% { box-shadow: 0 0 32px rgba(60,120,255,0.4); border-color: rgba(120,180,255,0.9); }
  }
  .fc-node--locked {
    opacity: 0.35;
  }
  .fc-node--ending {
    border-radius: 18px;
    border-color: rgba(220,190,80,0.2);
    font-size: 12px;
    padding: 7px 14px;
  }
  .fc-node--ending.fc-node--completed {
    border-color: rgba(220,195,80,0.55);
    color: #e0d080;
    background: rgba(40,35,20,0.9);
    box-shadow: 0 0 16px rgba(200,180,50,0.15);
  }
  .fc-node--ending.fc-node--current {
    border-color: rgba(240,215,80,0.75);
    color: #f5e8a0;
    background: linear-gradient(135deg, rgba(50,45,20,0.95) 0%, rgba(60,50,25,0.95) 100%);
    box-shadow: 0 0 24px rgba(220,200,50,0.25);
  }
  .fc-line--visited { stroke: rgba(90,145,250,0.4); stroke-width: 2; fill: none; }
  .fc-line--dim { stroke: rgba(70,90,150,0.18); stroke-width: 1.5; fill: none; stroke-dasharray: 4 4; }
  .fc-choice-label {
    position: absolute; transform: translateX(-50%);
    font-size: 10px; color: rgba(140,160,210,0.4);
    white-space: nowrap; pointer-events: none; z-index: 1;
    letter-spacing: 0.5px;
  }
  .fc-choice-label--visited { color: rgba(150,180,240,0.65); }

  /* ========== 交互玩法样式 ========== */
  .mini-game-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    z-index: 150; display: flex; justify-content: center; align-items: center;
    background: rgba(2,2,8,0.92);
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    animation: mgFadeIn 0.5s ease;
  }
  @keyframes mgFadeIn { from { opacity: 0; } to { opacity: 1; } }
  .mg-panel {
    background: linear-gradient(180deg, rgba(18,20,38,0.97) 0%, rgba(12,12,22,0.99) 100%);
    border: 1px solid rgba(100,140,255,0.2);
    border-radius: 18px; padding: 28px 24px;
    width: calc(100% - 40px); max-width: 400px;
    text-align: center;
    box-shadow: 0 12px 50px rgba(0,0,0,0.6);
  }
  .mg-title {
    font-size: 14px; color: rgba(180,200,240,0.7);
    letter-spacing: 4px; margin-bottom: 6px;
  }
  .mg-desc {
    font-size: 14px; color: #b8c8e8; line-height: 1.8;
    margin-bottom: 20px;
  }
  .mg-hint {
    font-size: 12px; color: rgba(160,180,220,0.5);
    margin-top: 14px;
  }
  .mg-skip-btn {
    display: block; margin: 16px auto 0;
    background: none; border: none;
    color: rgba(140,155,190,0.4); font-size: 12px;
    cursor: pointer; letter-spacing: 1px;
    transition: color 0.3s ease;
    padding: 4px 12px;
  }
  .mg-skip-btn:hover, .mg-skip-btn:active {
    color: rgba(180,190,220,0.7);
  }

  /* 密码输入 */
  .mg-code-input {
    display: flex; gap: 8px; justify-content: center; margin-bottom: 16px;
  }
  .mg-code-input input {
    width: 44px; height: 52px; text-align: center;
    background: rgba(40,50,80,0.6); border: 1px solid rgba(100,140,255,0.3);
    border-radius: 10px; color: #e0ecff; font-size: 22px; font-weight: bold;
    font-family: 'Courier New', monospace;
    outline: none; transition: all 0.3s ease;
  }
  .mg-code-input input:focus {
    border-color: rgba(120,170,255,0.7);
    box-shadow: 0 0 12px rgba(80,130,255,0.2);
  }
  .mg-code-input input.mg-correct {
    border-color: rgba(100,200,120,0.7);
    background: rgba(40,80,50,0.5);
    color: #90e8a0;
  }
  .mg-code-input input.mg-wrong {
    border-color: rgba(220,80,80,0.7);
    background: rgba(80,30,30,0.5);
    color: #f08080;
    animation: mgShake 0.4s ease;
  }
  @keyframes mgShake {
    0%,100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    75% { transform: translateX(6px); }
  }
  .mg-submit-btn {
    background: rgba(60,100,200,0.15); border: 1px solid rgba(100,140,255,0.35);
    border-radius: 10px; padding: 10px 28px; color: #a0c4ff;
    font-size: 14px; cursor: pointer; transition: all 0.3s ease;
    letter-spacing: 2px;
  }
  .mg-submit-btn:active {
    background: rgba(60,100,200,0.35); border-color: rgba(120,170,255,0.7); color: #fff;
  }

  /* QTE 快速反应 */
  .mg-qte-zone {
    position: relative; width: 100%; height: 120px;
    margin-bottom: 16px; overflow: hidden;
    border-radius: 12px; background: rgba(30,35,55,0.6);
    border: 1px solid rgba(80,110,180,0.2);
  }
  .mg-qte-target {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 60px; height: 60px; border-radius: 50%;
    background: radial-gradient(circle, rgba(255,100,80,0.9) 0%, rgba(200,60,40,0.6) 100%);
    border: 2px solid rgba(255,140,120,0.7);
    display: flex; justify-content: center; align-items: center;
    font-size: 20px; color: #fff; cursor: pointer;
    animation: qteAppear 0.3s ease;
    box-shadow: 0 0 20px rgba(255,80,60,0.3);
    transition: transform 0.1s ease;
    user-select: none;
  }
  .mg-qte-target:active { transform: translateY(-50%) scale(0.9); }
  @keyframes qteAppear { from { transform: translateY(-50%) scale(0); } to { transform: translateY(-50%) scale(1); } }
  .mg-qte-target.mg-hit {
    background: radial-gradient(circle, rgba(100,220,120,0.9) 0%, rgba(60,180,80,0.6) 100%);
    border-color: rgba(120,240,140,0.7);
    box-shadow: 0 0 20px rgba(80,220,100,0.3);
    animation: qteHit 0.3s ease forwards;
  }
  @keyframes qteHit { to { transform: translateY(-50%) scale(1.3); opacity: 0; } }
  .mg-qte-progress {
    width: 100%; height: 6px; background: rgba(255,255,255,0.1);
    border-radius: 3px; overflow: hidden; margin-bottom: 10px;
  }
  .mg-qte-progress-fill {
    height: 100%; border-radius: 3px;
    background: linear-gradient(90deg, #ff6b35, #ffab70);
    transition: width 0.3s ease;
  }
  .mg-qte-timer {
    font-size: 28px; font-weight: bold; color: #ff8a65;
    font-variant-numeric: tabular-nums; margin-bottom: 8px;
  }

  /* 信号调频 */
  .mg-freq-display {
    position: relative; width: 100%; height: 80px;
    margin-bottom: 16px; border-radius: 12px;
    background: rgba(15,25,40,0.8); border: 1px solid rgba(60,100,180,0.25);
    overflow: hidden;
  }
  .mg-freq-wave {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  }
  .mg-freq-target-line {
    position: absolute; top: 50%; left: 0; right: 0;
    height: 2px; background: rgba(100,220,120,0.4);
    transform: translateY(-50%);
  }
  .mg-freq-label {
    font-size: 12px; color: rgba(160,180,220,0.6);
    margin-bottom: 8px; display: flex; justify-content: space-between;
  }
  .mg-freq-slider {
    width: 100%; -webkit-appearance: none; appearance: none;
    height: 8px; border-radius: 4px;
    background: linear-gradient(90deg, rgba(40,60,100,0.6), rgba(60,100,180,0.6));
    outline: none; margin-bottom: 12px;
  }
  .mg-freq-slider::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none;
    width: 24px; height: 24px; border-radius: 50%;
    background: radial-gradient(circle, #a0c4ff 0%, #6090e0 100%);
    border: 2px solid rgba(140,180,255,0.8);
    cursor: pointer; box-shadow: 0 0 10px rgba(80,130,255,0.3);
  }
  .mg-freq-match {
    font-size: 16px; font-weight: bold; color: #90e8a0;
    margin-bottom: 8px;
  }
  .mg-freq-lock-btn {
    background: rgba(60,160,80,0.15); border: 1px solid rgba(80,200,100,0.35);
    border-radius: 10px; padding: 10px 28px; color: #80d890;
    font-size: 14px; cursor: pointer; transition: all 0.3s ease;
    letter-spacing: 2px; opacity: 0.4; pointer-events: none;
  }
  .mg-freq-lock-btn.mg-active {
    opacity: 1; pointer-events: auto;
  }
  .mg-freq-lock-btn.mg-active:active {
    background: rgba(60,160,80,0.35); border-color: rgba(100,220,120,0.7); color: #fff;
  }

  /* 迷雾擦除 */
  .mg-fog-wrap {
    position: relative; width: 100%; height: 200px; border-radius: 12px;
    margin-bottom: 14px; overflow: hidden;
    border: 1px solid rgba(80,110,180,0.2);
  }
  .mg-fog-canvas, .mg-fog-bg {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100%;
    cursor: crosshair; touch-action: none;
  }
  .mg-fog-bg { z-index: 0; object-fit: cover; border-radius: 12px; }
  .mg-fog-canvas { z-index: 1; }
  .mg-fog-progress {
    width: 100%; height: 6px; background: rgba(255,255,255,0.1);
    border-radius: 3px; overflow: hidden; margin-bottom: 10px;
  }
  .mg-fog-progress-fill {
    height: 100%; border-radius: 3px;
    background: linear-gradient(90deg, rgba(180,200,240,0.4), rgba(220,230,255,0.8));
    transition: width 0.2s ease;
  }

  /* 报纸碎片拼合 */
  .mg-puzzle-zone {
    position: relative; width: 100%; height: 180px;
    margin-bottom: 14px; border-radius: 12px;
    background: rgba(25,28,45,0.7); border: 1px solid rgba(80,110,180,0.2);
    overflow: hidden;
  }
  .mg-puzzle-piece {
    position: absolute; padding: 6px 10px;
    background: rgba(50,45,35,0.9); border: 1px solid rgba(180,160,100,0.4);
    border-radius: 6px; font-size: 13px; color: #d8d0b8;
    cursor: grab; user-select: none; touch-action: none;
    transition: box-shadow 0.2s ease;
    font-family: 'SimSun', serif;
  }
  .mg-puzzle-piece:active { cursor: grabbing; }
  .mg-puzzle-piece.mg-dragging {
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
    z-index: 10; opacity: 0.9;
  }
  .mg-puzzle-slot {
    position: absolute; padding: 6px 10px;
    border: 1.5px dashed rgba(180,160,100,0.35);
    border-radius: 6px; font-size: 13px; color: transparent;
    font-family: 'SimSun', serif;
  }
  .mg-puzzle-slot.mg-filled {
    border-color: rgba(100,200,120,0.5);
    background: rgba(40,70,50,0.4);
    color: #a0d8a8;
  }

  /* 电梯长按 */
  .mg-hold-zone {
    position: relative; width: 100%; margin-bottom: 14px;
  }
  .mg-hold-btn {
    width: 100px; height: 100px; border-radius: 50%;
    background: radial-gradient(circle, rgba(80,130,220,0.7) 0%, rgba(40,70,150,0.5) 100%);
    border: 3px solid rgba(120,170,255,0.5);
    color: #d0e0ff; font-size: 14px; letter-spacing: 2px;
    cursor: pointer; user-select: none; touch-action: none;
    display: flex; justify-content: center; align-items: center;
    margin: 0 auto; transition: all 0.2s ease;
    box-shadow: 0 0 20px rgba(60,110,240,0.2);
  }
  .mg-hold-btn.mg-pressing {
    background: radial-gradient(circle, rgba(100,180,255,0.9) 0%, rgba(60,110,220,0.7) 100%);
    border-color: rgba(150,200,255,0.8);
    box-shadow: 0 0 35px rgba(80,140,255,0.4);
    transform: scale(0.95);
  }
  .mg-hold-btn.mg-fail {
    background: radial-gradient(circle, rgba(220,80,60,0.7) 0%, rgba(150,40,30,0.5) 100%);
    border-color: rgba(255,100,80,0.5);
    box-shadow: 0 0 20px rgba(220,60,40,0.3);
  }
  .mg-hold-floor {
    font-size: 36px; font-weight: bold; color: #a0c4ff;
    font-variant-numeric: tabular-nums; margin-bottom: 10px;
    text-align: center;
  }
  .mg-hold-glitch {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none; display: flex; justify-content: center; align-items: center;
    font-size: 13px; color: rgba(255,80,60,0.8); letter-spacing: 1px;
    animation: glitchFlash 0.15s ease;
    text-shadow: 0 0 8px rgba(255,60,40,0.4);
  }
  @keyframes glitchFlash { 0% { opacity: 0; transform: scale(1.2); } 100% { opacity: 1; transform: scale(1); } }

  /* 打字挑战 */
  .mg-type-display {
    width: 100%; padding: 14px; border-radius: 10px;
    background: rgba(10,15,25,0.9); border: 1px solid rgba(60,100,180,0.25);
    font-family: 'Courier New', monospace; font-size: 15px;
    color: #60a0d0; margin-bottom: 12px; min-height: 48px;
    letter-spacing: 1px; text-align: left; line-height: 1.6;
    overflow: hidden;
  }
  .mg-type-display .mg-typed { color: #90e8a0; }
  .mg-type-display .mg-cursor-char { color: #fff; background: rgba(100,200,120,0.4); }
  .mg-type-display .mg-untyped { color: rgba(100,140,200,0.5); }
  .mg-type-input {
    width: 100%; padding: 12px 14px; border-radius: 10px;
    background: rgba(20,25,40,0.8); border: 1px solid rgba(80,120,200,0.3);
    color: #e0ecff; font-size: 15px; font-family: 'Courier New', monospace;
    outline: none; margin-bottom: 12px; letter-spacing: 1px;
  }
  .mg-type-input:focus {
    border-color: rgba(120,170,255,0.6);
    box-shadow: 0 0 10px rgba(80,130,255,0.15);
  }
  .mg-type-progress {
    width: 100%; height: 6px; background: rgba(255,255,255,0.1);
    border-radius: 3px; overflow: hidden; margin-bottom: 8px;
  }
  .mg-type-progress-fill {
    height: 100%; border-radius: 3px;
    background: linear-gradient(90deg, #40a060, #80e0a0);
    transition: width 0.3s ease;
  }

  /* 推门连点 */
  .mg-mash-zone { text-align: center; margin-bottom: 14px; }
  .mg-mash-btn {
    width: 120px; height: 120px; border-radius: 50%;
    background: radial-gradient(circle, rgba(200,160,60,0.7) 0%, rgba(150,110,30,0.5) 100%);
    border: 3px solid rgba(240,200,80,0.5);
    color: #f0e0a0; font-size: 28px;
    cursor: pointer; user-select: none; touch-action: none;
    display: inline-flex; justify-content: center; align-items: center;
    transition: transform 0.08s ease;
    box-shadow: 0 0 20px rgba(200,160,40,0.2);
  }
  .mg-mash-btn:active {
    transform: scale(0.92);
    background: radial-gradient(circle, rgba(240,200,80,0.9) 0%, rgba(180,140,40,0.7) 100%);
    box-shadow: 0 0 30px rgba(240,200,60,0.4);
  }
  .mg-mash-bar {
    width: 100%; height: 14px; background: rgba(255,255,255,0.08);
    border-radius: 7px; overflow: hidden; margin-bottom: 10px;
    border: 1px solid rgba(200,160,60,0.2);
  }
  .mg-mash-bar-fill {
    height: 100%; border-radius: 7px;
    background: linear-gradient(90deg, #c0900a, #f0c830);
    transition: width 0.1s ease;
  }
  .mg-mash-crack {
    font-size: 12px; color: rgba(200,180,120,0.6);
    margin-top: 6px;
  }

  /* ========== 视频背景 ========== */
  .scene-video {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: contain;
    background: transparent;
    z-index: 3;
    opacity: 0;
    pointer-events: none;
  }
  .scene-video.active {
    opacity: 1;
  }
  .scene-video.fade-in {
    transition: opacity 0.4s ease;
  }
  .scene-video.fade-out {
    transition: opacity 0.3s ease;
  }
</style>
</head>
<body>
<div id="game">
  <div id="scene-bg"></div>
  <video id="scene-video-a" class="scene-video" muted playsinline></video>
  <video id="scene-video-b" class="scene-video" muted playsinline></video>
  <audio id="bgm" loop src="./bgm.mp3"></audio>
  <div id="fog"></div>
  <canvas id="particles"></canvas>

  <div id="status-panel">
    <div id="status-header">
      <div id="chapter-name">第一章 · 醒来</div>
    </div>
    <div id="stat-bars">
      <div class="stat-item stat-courage">
        <div class="stat-label"><span class="stat-icon">&#9876;</span> 勇气</div>
        <div class="stat-bar-bg"><div class="stat-bar-fill" id="bar-courage" style="width:50%"></div></div>
        <div class="stat-value" id="val-courage">50</div>
      </div>
      <div class="stat-item stat-reason">
        <div class="stat-label"><span class="stat-icon">&#9881;</span> 理性</div>
        <div class="stat-bar-bg"><div class="stat-bar-fill" id="bar-reason" style="width:50%"></div></div>
        <div class="stat-value" id="val-reason">50</div>
      </div>
      <div class="stat-item stat-bond">
        <div class="stat-label"><span class="stat-icon">&#9829;</span> 羁绊</div>
        <div class="stat-bar-bg"><div class="stat-bar-fill" id="bar-bond" style="width:50%"></div></div>
        <div class="stat-value" id="val-bond">50</div>
      </div>
    </div>
  </div>

  <button id="menu-btn" aria-label="菜单">&#9776;</button>
  <div id="transition-overlay"></div>
  <div id="no-video-hint"><div class="no-video-content"><div class="no-video-icon">&#9881;</div><div class="no-video-text">素材暂缺</div></div></div>

  <div id="menu-overlay">
    <div id="menu-panel">
      <button id="menu-close" aria-label="关闭">&times;</button>
      <div id="menu-main" class="active">
        <div id="menu-title">菜 单</div>
        <button class="menu-option" data-action="save"><span class="menu-option-icon">&#128190;</span> 存档</button>
        <button class="menu-option" data-action="load"><span class="menu-option-icon">&#128194;</span> 读档</button>
        <button class="menu-option" data-action="log"><span class="menu-option-icon">&#128220;</span> 剧情回顾</button>
        <button class="menu-option" data-action="flowchart"><span class="menu-option-icon">&#128268;</span> 剧情分支</button>
      </div>
      <div id="menu-save">
        <button class="menu-back" data-back>&larr; 返回</button>
        <div class="sub-title">存 档</div>
        <div id="save-slots"></div>
      </div>
      <div id="menu-load">
        <button class="menu-back" data-back>&larr; 返回</button>
        <div class="sub-title">读 档</div>
        <div id="load-slots"></div>
      </div>
      <div id="menu-log">
        <button class="menu-back" data-back>&larr; 返回</button>
        <div class="sub-title">剧 情 回 顾</div>
        <div class="log-list" id="log-list"></div>
      </div>
    </div>
  </div>

  <div id="title-screen">
    <div class="title-particles" id="title-particles"></div>
    <div class="title-code">#0217 // SUBJECT_AWAKEN</div>
    <h1>迷 雾 城</h1>
    <div class="subtitle">CITY OF MIST</div>
    <div class="tagline">你在迷雾中醒来，记忆全无。每一个选择，都将改变你的命运。</div>
    <button id="start-btn">开 始 探 索</button>
  </div>

  <div id="ending-screen">
    <div class="ending-label">— 结 局 —</div>
    <h1 id="ending-title"></h1>
    <p class="ending-desc" id="ending-desc"></p>
    <div id="ending-stats"></div>
    <button id="restart-btn">重 新 开 始</button>
  </div>

  <div id="flowchart-overlay">
    <div id="flowchart-panel">

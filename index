function applyStat(changes) {
  if (!changes) return;
  const nameMap = { courage: '勇气', reason: '理性', bond: '羁绊' };
  const colorMap = { courage: '#ff8a65', reason: '#64b5f6', bond: '#ce93d8' };
  Object.keys(changes).forEach(k => {
    const old = stats[k];
    stats[k] = clamp(stats[k] + changes[k]);
    if (stats[k] !== old) showStatChange(k, changes[k], colorMap[k], nameMap[k]);
  });
  updateStatUI();
}
function showStatChange(key, delta, color, name) {
  const el = document.createElement('div');

function highlightText(text, nodeId) {
  const kws = nodeKeywords[nodeId];
  if (!kws || kws.length === 0) return text;
  let result = text;
  const tokens = [];
  let count = 0;
  for (const kw of kws) {
    if (count >= 2) break;
    const re = new RegExp(kw.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
    const newResult = result.replace(re, match => {
      const idx = tokens.length;
      tokens.push(`<span class="kw">${match}</span>`);
      return `\x00${idx}\x00`;
    });
    if (newResult !== result) { result = newResult; count++; }
  }
  tokens.forEach((html, i) => {
    result = result.replace(`\x00${i}\x00`, html);
  });
  return result;
}


let nodeHistory = [];

function typeText(text, callback, nodeId) {
  const highlighted = highlightText(text, nodeId);
  fullText = highlighted;
  // Build a map: for each plain-text index, what's the corresponding position in the HTML string
  const plainChars = [];
  const htmlParts = [];
  let inTag = false;
  let buf = '';
  for (let i = 0; i < highlighted.length; i++) {
    const ch = highlighted[i];
    if (ch === '<') { inTag = true; buf += ch; continue; }
    if (inTag) { buf += ch; if (ch === '>') { inTag = false; } continue; }
    // visible character
    htmlParts.push(buf + ch);
    buf = '';
    plainChars.push(ch);
  }
  if (buf) htmlParts[htmlParts.length - 1] += buf; // trailing close tags

  charIndex = 0; isTyping = true;
  textEl.innerHTML = ''; continueHint.style.display = 'none'; choicesEl.innerHTML = '';

  function typeNext() {
    if (charIndex < plainChars.length) {
      // Build partial HTML up to current char, ensuring all tags are closed
      let partial = '';
      for (let i = 0; i <= charIndex; i++) partial += htmlParts[i];
      // Close any unclosed span tags
      const opens = (partial.match(/<span[^>]*>/g) || []).length;
      const closes = (partial.match(/<\/span>/g) || []).length;
      for (let i = 0; i < opens - closes; i++) partial += '</span>';
      textEl.innerHTML = partial + '<span class="cursor"></span>';
      charIndex++;
      typeTimer = setTimeout(typeNext, 18);
    } else {
      textEl.innerHTML = fullText; isTyping = false;
      if (callback) callback();
    }
  }
  typeNext();
}

function skipType() {
  if (isTyping) {
    clearTimeout(typeTimer);
    textEl.innerHTML = fullText; isTyping = false;
    showAfterText();
  }
}

function showAfterText() {
  const node = story[currentNode];
  if (node.ending) {
    setTimeout(() => showEnding(node.ending), 800);
  } else if (node.choices) {
    showChoices(node.choices);
  } else if (node.next) {
    continueHint.style.display = 'block';
  }
}

function showChoices(choices) {
  choicesEl.innerHTML = '';
  choices.forEach((c, i) => {
    const btn = document.createElement('button');
    btn.className = 'choice-btn';
    const hint = formatStatHint(c.stat);
    btn.innerHTML = `<span>${c.text}</span>${hint ? '<div class="choice-stat-hint">' + hint + '</div>' : ''}`;
    btn.style.opacity = '0'; btn.style.transform = 'translateY(8px)';
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      choiceCount++;
      if (c.stat) applyStat(c.stat);
      goToNode(c.next);
    });
    choicesEl.appendChild(btn);
    setTimeout(() => {
      btn.style.transition = 'all 0.4s ease';
      btn.style.opacity = '1'; btn.style.transform = 'translateY(0)';
    }, 120 * (i + 1));
  });
}

function showEnding(ending) {
  dialogBox.style.display = 'none';
  document.getElementById('menu-btn').style.display = 'none';
  noVideoHint.classList.remove('active');
  resetVideo(videoA);
  resetVideo(videoB);
  activeVideo = videoA; standbyVideo = videoB;
  videoPlaying = false;
  endingScreen.style.display = 'flex';
  endingScreen.style.opacity = '0';
  document.getElementById('ending-title').textContent = ending.title;
  document.getElementById('ending-desc').textContent = ending.desc;
  const endStats = document.getElementById('ending-stats');
  const colorMap = { courage: '#ff8a65', reason: '#64b5f6', bond: '#ce93d8' };
  const nameMap = { courage: '勇气', reason: '理性', bond: '羁绊' };
  endStats.innerHTML = Object.keys(stats).map(k =>
    `<div class="ending-stat"><div class="ending-stat-val" style="color:${colorMap[k]}">${stats[k]}</div><div class="ending-stat-label">${nameMap[k]}</div></div>`
  ).join('');
  setTimeout(() => { endingScreen.style.transition = 'opacity 1.5s ease'; endingScreen.style.opacity = '1'; }, 100);
}


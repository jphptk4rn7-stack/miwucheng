  el.style.left = rect.left - gameRect.left + rect.width / 2 - 20 + 'px';
  el.style.top = rect.top - gameRect.top + 16 + 'px';
  document.getElementById('game').appendChild(el);
  setTimeout(() => el.remove(), 1300);
}
function formatStatHint(s) {
  if (!s) return '';
  const nameMap = { courage: '勇气', reason: '理性', bond: '羁绊' };

function getFlowchartNodeState(fcNode) {
  const isCurrent = fcNode.storyNodes.includes(currentNode);
  if (isCurrent) return 'current';
  const everVisited = fcNode.storyNodes.some(sn => allVisitedNodes.has(sn));
  if (everVisited) return 'completed';
  return 'locked';
}

function isPathVisited(parentFcNode, childId) {
  const parentVisited = parentFcNode.storyNodes.some(sn => allVisitedNodes.has(sn));
  const childFc = flowchartData.find(n => n.id === childId);
  const childVisited = childFc && childFc.storyNodes.some(sn => allVisitedNodes.has(sn));
  return parentVisited && childVisited;
}

function renderFlowchart() {
  const tree = document.getElementById('flowchart-tree');
  tree.innerHTML = '';

  const colW = 80, rowH = 82;
  const totalCols = 7.2, totalRows = 5;
  const padX = 38, padY = 20;
  const treeW = Math.ceil(totalCols * colW + padX * 2);
  const treeH = Math.ceil(totalRows * rowH + padY * 2);
  tree.style.width = treeW + 'px';
  tree.style.height = treeH + 'px';
  tree.style.margin = '0 auto';

  const nodePositions = {};
  const nodeH = 34;
  flowchartData.forEach(fc => {
    const lay = flowchartLayout[fc.id];
    const x = padX + lay.col * colW;
    const y = padY + lay.row * rowH;
    nodePositions[fc.id] = { x, y };
  });

  // SVG for curved lines
  const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
  svg.setAttribute('width', treeW);
  svg.setAttribute('height', treeH);
  svg.style.width = treeW + 'px';
  svg.style.height = treeH + 'px';

  flowchartData.forEach(fc => {
    fc.children.forEach(ch => {
      const from = nodePositions[fc.id];
      const to = nodePositions[ch.targetId];
      if (!from || !to) return;
      const visited = isPathVisited(fc, ch.targetId);
      const y1 = from.y + nodeH;
      const y2 = to.y - 2;
      const midY = (y1 + y2) / 2;
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('d', `M${from.x},${y1} C${from.x},${midY} ${to.x},${midY} ${to.x},${y2}`);
      path.setAttribute('class', visited ? 'fc-line--visited' : 'fc-line--dim');
      svg.appendChild(path);

      if (ch.choiceLabel) {
        const lbl = document.createElement('div');
        lbl.className = 'fc-choice-label' + (visited ? ' fc-choice-label--visited' : '');
        lbl.textContent = ch.choiceLabel;
        lbl.style.left = ((from.x + to.x) / 2) + 'px';
        lbl.style.top = (midY - 6) + 'px';
        tree.appendChild(lbl);
      }
    });
  });

  tree.appendChild(svg);

  // Render nodes on top of lines
  flowchartData.forEach(fc => {
    const state = getFlowchartNodeState(fc);
    const pos = nodePositions[fc.id];
    const div = document.createElement('div');
    div.className = 'fc-node fc-node--' + state + (fc.type === 'ending' ? ' fc-node--ending' : '');
    div.style.left = pos.x + 'px';
    div.style.top = pos.y + 'px';
    div.textContent = state === 'locked' ? '???' : fc.label;
    if (state === 'completed' || state === 'current') {
      div.addEventListener('click', (e) => { e.stopPropagation(); jumpToFlowchartNode(fc.id); });
    }
    tree.appendChild(div);
  });
}

function jumpToFlowchartNode(fcNodeId) {
  const fcNode = flowchartData.find(n => n.id === fcNodeId);
  if (!fcNode) return;

  // Find the first story node of this flowchart node in history
  const targetStoryNode = fcNode.storyNodes[0];
  const histIdx = nodeHistory.findIndex(h => fcNode.storyNodes.includes(h.id));

  if (histIdx === -1) return;

  // Truncate history to that point
  nodeHistory = nodeHistory.slice(0, histIdx);

  // Replay stats from scratch
  stats = { courage: 50, reason: 50, bond: 50 };
  choiceCount = 0;
  nodeHistory.forEach(h => {
    const node = story[h.id];
    if (node && node.stat) {
      Object.keys(node.stat).forEach(k => { stats[k] = clamp(stats[k] + node.stat[k]); });
    }
  });

  // Also replay choice stats by checking if a node had choices and the next history entry tells us which was picked
  for (let i = 0; i < nodeHistory.length; i++) {
    const node = story[nodeHistory[i].id];
    if (node && node.choices && i + 1 < nodeHistory.length) {
      const nextId = nodeHistory[i + 1].id;
      const picked = node.choices.find(c => c.next === nextId);
      if (picked && picked.stat) {
        choiceCount++;
        Object.keys(picked.stat).forEach(k => { stats[k] = clamp(stats[k] + picked.stat[k]); });
      }
    }
  }

  updateStatUI();
  closeFlowchart();

  // Ensure game UI is visible
  titleScreen.style.display = 'none';
  titleScreen.classList.add('fade-out');
  endingScreen.style.display = 'none';
  dialogBox.style.display = 'block';
  statusPanel.style.display = 'block';
  menuBtn.style.display = 'flex';

  goToNode(targetStoryNode);
}


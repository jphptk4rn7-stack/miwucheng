// ========== 存档 / 读档 ==========
function getSaveData(slot) {
  try { return JSON.parse(localStorage.getItem('mistcity_save_' + slot)); } catch(e) { return null; }
}

function saveGame(slot) {
  const node = story[currentNode];
  const data = {
    currentNode, stats: {...stats}, choiceCount, nodeHistory: [...nodeHistory],
    time: new Date().toLocaleString('zh-CN'),
    chapter: chapterNames[node ? node.scene : 'wake'] || '未知'
  };
  localStorage.setItem('mistcity_save_' + slot, JSON.stringify(data));
  renderSaveSlots();
}

function loadGame(slot) {
  const data = getSaveData(slot);
  if (!data) return;
  stats = data.stats;
  choiceCount = data.choiceCount;
  nodeHistory = data.nodeHistory || [];
  updateStatUI();
  // Ensure game UI is visible
  titleScreen.style.display = 'none';
  titleScreen.classList.add('fade-out');
  endingScreen.style.display = 'none';
  dialogBox.style.display = 'block';
  statusPanel.style.display = 'block';
  menuBtn.style.display = 'flex';
  closeMenu();
  goToNode(data.currentNode);
}

function renderSlotHTML(slot, isLoad) {
  const data = getSaveData(slot);
  if (data) {
    return `<div class="save-slot" data-slot="${slot}">
      <div class="save-slot-header">
        <span class="save-slot-label">存档 ${slot}</span>
        <span class="save-slot-time">${data.time}</span>
      </div>
      <div class="save-slot-info">${data.chapter}</div>
      <div class="save-slot-stats">
        <span>勇气 ${data.stats.courage}</span>
        <span>理性 ${data.stats.reason}</span>
        <span>羁绊 ${data.stats.bond}</span>
      </div>
    </div>`;
  }
  const cls = isLoad ? 'save-slot empty slot-disabled' : 'save-slot empty';
  return `<div class="${cls}" data-slot="${slot}">
    <div class="save-slot-header"><span class="save-slot-label">存档 ${slot}</span></div>
    <div class="save-slot-info">— 空 —</div>
  </div>`;
}

function renderSaveSlots() {
  const container = document.getElementById('save-slots');
  container.innerHTML = [1,2,3].map(s => renderSlotHTML(s, false)).join('');
  container.querySelectorAll('.save-slot').forEach(el => {
    el.addEventListener('click', () => saveGame(parseInt(el.dataset.slot)));
  });
}

function renderLoadSlots() {
  const container = document.getElementById('load-slots');
  container.innerHTML = [1,2,3].map(s => renderSlotHTML(s, true)).join('');
  container.querySelectorAll('.save-slot:not(.slot-disabled)').forEach(el => {
    el.addEventListener('click', () => loadGame(parseInt(el.dataset.slot)));
  });
}

// ========== 剧情回顾 ==========
function renderLog() {
  const list = document.getElementById('log-list');
  if (nodeHistory.length === 0) {
    list.innerHTML = '<div class="log-empty">暂无剧情记录</div>';
    return;
  }
  let lastScene = null;
  list.innerHTML = nodeHistory.map(h => {
    const chapter = chapterNames[h.scene] || '';
    const excerpt = h.text.length > 60 ? h.text.slice(0, 60) + '…' : h.text;
    const showChapter = h.scene !== lastScene;
    lastScene = h.scene;
    return `${showChapter ? '<div class="log-chapter-divider">' + chapter + '</div>' : ''}<div class="log-item">
      ${h.speaker ? '<div class="log-speaker">' + h.speaker + '</div>' : ''}
      <div class="log-text">${excerpt}</div>
    </div>`;
  }).join('');
  list.scrollTop = list.scrollHeight;
}

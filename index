// --- 信号调频小游戏（记忆线场景） ---
function startFreqTune(targetFreq, onSuccess, onFail) {
  const { overlay, panel } = createMiniGameOverlay(onFail || onSuccess);
  panel.innerHTML = `
    <div class="mg-title">信 号 调 频</div>
    <div class="mg-desc">通讯器发出刺耳的杂音。<br>调整频率，找到正确的信号……</div>
    <div class="mg-freq-display">
      <div class="mg-freq-target-line"></div>
      <canvas class="mg-freq-wave" id="mg-freq-canvas"></canvas>
    </div>
    <div class="mg-freq-label"><span>87.5 MHz</span><span id="mg-freq-val">93.8 MHz</span><span>108.0 MHz</span></div>
    <input type="range" class="mg-freq-slider" id="mg-freq-slider" min="875" max="1080" value="938" step="1">
    <div class="mg-freq-match" id="mg-freq-match">&nbsp;</div>
    <button class="mg-freq-lock-btn" id="mg-freq-lock">锁 定 信 号</button>
    <div class="mg-hint">缓慢滑动，当信号匹配度达到 90% 以上时锁定</div>
  `;
  overlay._addSkip();
  const slider = panel.querySelector('#mg-freq-slider');
  const valLabel = panel.querySelector('#mg-freq-val');
  const matchLabel = panel.querySelector('#mg-freq-match');
  const lockBtn = panel.querySelector('#mg-freq-lock');
  const canvas = panel.querySelector('#mg-freq-canvas');
  const fctx = canvas.getContext('2d');

  function resizeFreqCanvas() {
    canvas.width = canvas.parentElement.offsetWidth;
    canvas.height = canvas.parentElement.offsetHeight;
  }
  resizeFreqCanvas();

  let currentFreq = 938;
  let animFrame;

  function drawWave() {
    const w = canvas.width, h = canvas.height;
    fctx.clearRect(0, 0, w, h);
    const diff = Math.abs(currentFreq - targetFreq);
    const matchPct = Math.max(0, 100 - diff * 2);
    const amplitude = matchPct > 80 ? 15 + (matchPct - 80) * 0.5 : 5 + Math.random() * 20;
    const noise = matchPct > 80 ? 2 : 15 - matchPct * 0.1;

    fctx.beginPath();
    fctx.strokeStyle = matchPct > 90 ? 'rgba(100,220,120,0.8)' : matchPct > 60 ? 'rgba(220,200,80,0.7)' : 'rgba(200,100,80,0.6)';
    fctx.lineWidth = 2;
    for (let x = 0; x < w; x++) {
      const t = Date.now() * 0.003 + x * 0.05;
      const y = h / 2 + Math.sin(t) * amplitude + (Math.random() - 0.5) * noise;
      if (x === 0) fctx.moveTo(x, y); else fctx.lineTo(x, y);
    }
    fctx.stroke();
    animFrame = requestAnimationFrame(drawWave);
  }
  drawWave();

  slider.addEventListener('input', () => {
    currentFreq = parseInt(slider.value);
    valLabel.textContent = (currentFreq / 10).toFixed(1) + ' MHz';
    const diff = Math.abs(currentFreq - targetFreq);
    const matchPct = Math.max(0, Math.min(100, 100 - diff * 2));
    matchLabel.textContent = `信号匹配：${matchPct}%`;
    matchLabel.style.color = matchPct > 90 ? '#90e8a0' : matchPct > 60 ? '#e0d080' : '#f08080';
    if (matchPct >= 90) {
      lockBtn.classList.add('mg-active');
    } else {
      lockBtn.classList.remove('mg-active');
    }
  });

  lockBtn.addEventListener('click', () => {
    if (!lockBtn.classList.contains('mg-active')) return;
    cancelAnimationFrame(animFrame);
    matchLabel.textContent = '信号已锁定！';
    matchLabel.style.color = '#90e8a0';
    lockBtn.style.display = 'none';
    panel.querySelector('.mg-hint').textContent = '连接成功';
    panel.querySelector('.mg-hint').style.color = '#90e8a0';
    applyStat({ bond: 5 });
    removeMiniGame(overlay, 1200);
    setTimeout(onSuccess, 1400);
  });
}

// --- 迷雾擦除（醒来场景） ---
function startFogWipe(threshold, onComplete, onFail) {
  const { overlay, panel } = createMiniGameOverlay(onFail || onComplete);
  panel.innerHTML = `
    <div class="mg-title">迷 雾 中 醒 来</div>
    <div class="mg-desc">眼前一片模糊……用手指拨开迷雾，看清周围的环境。</div>
    <div class="mg-fog-wrap">
      <img class="mg-fog-bg" src="./fog.jpeg" alt="">
      <canvas class="mg-fog-canvas" id="mg-fog-canvas"></canvas>
    </div>
    <div class="mg-fog-progress"><div class="mg-fog-progress-fill" id="mg-fog-fill" style="width:0%"></div></div>
    <div class="mg-hint">在画面上滑动擦除迷雾</div>
  `;
  overlay._addSkip();
  const cvs = panel.querySelector('#mg-fog-canvas');
  const fctx = cvs.getContext('2d');
  const fillBar = panel.querySelector('#mg-fog-fill');
  let completed = false;

  setTimeout(() => {
    cvs.width = cvs.offsetWidth;
    cvs.height = cvs.offsetHeight;
    const w = cvs.width, h = cvs.height;
    // Canvas only holds the fog layer; the image is behind it via <img>
    fctx.fillStyle = 'rgba(200,210,230,0.92)';
    fctx.fillRect(0, 0, w, h);
  }, 100);

  let totalPixels = 0;
  let clearedPixels = 0;
  let isDrawing = false;

  function getPos(e) {
    const rect = cvs.getBoundingClientRect();
    const touch = e.touches ? e.touches[0] : e;
    return { x: (touch.clientX - rect.left) * (cvs.width / rect.width), y: (touch.clientY - rect.top) * (cvs.height / rect.height) };
  }

  function wipe(pos) {
    if (completed) return;
    fctx.globalCompositeOperation = 'destination-out';
    fctx.beginPath();
    fctx.arc(pos.x, pos.y, 22, 0, Math.PI * 2);
    fctx.fill();
    fctx.globalCompositeOperation = 'source-over';
    // Calculate cleared percentage
    const imgData = fctx.getImageData(0, 0, cvs.width, cvs.height);
    let transparent = 0;
    for (let i = 3; i < imgData.data.length; i += 4) {
      if (imgData.data[i] < 128) transparent++;
    }
    totalPixels = imgData.data.length / 4;
    clearedPixels = transparent;
    const pct = Math.min(100, (clearedPixels / totalPixels) * 100 / (threshold / 100));
    fillBar.style.width = pct + '%';
    if (pct >= 100 && !completed) {
      completed = true;
      isDrawing = false;
      panel.querySelector('.mg-hint').textContent = '迷雾散去了……';
      panel.querySelector('.mg-hint').style.color = '#b8d0f5';
      // Wait for hint to show, then fade out overlay, then proceed
      setTimeout(() => {
        overlay.style.pointerEvents = 'none';
        overlay.style.transition = 'opacity 0.6s ease';
        overlay.style.opacity = '0';
        setTimeout(() => {
          overlay.remove();
          onComplete();
        }, 650);
      }, 800);
    }
  }

  cvs.addEventListener('mousedown', (e) => { if (!completed) { isDrawing = true; wipe(getPos(e)); } });
  cvs.addEventListener('mousemove', (e) => { if (isDrawing && !completed) wipe(getPos(e)); });
  cvs.addEventListener('mouseup', () => { isDrawing = false; });
  cvs.addEventListener('touchstart', (e) => { e.preventDefault(); if (!completed) { isDrawing = true; wipe(getPos(e)); } }, { passive: false });
  cvs.addEventListener('touchmove', (e) => { e.preventDefault(); if (isDrawing && !completed) wipe(getPos(e)); }, { passive: false });
  cvs.addEventListener('touchend', () => { isDrawing = false; });
}

// --- 报纸碎片拼合（街道场景） ---
function startPuzzle(onComplete, onFail) {
  const { overlay, panel } = createMiniGameOverlay(onFail || onComplete);
  const fragments = [
    { text: '迷雾城', slotX: 20, slotY: 30 },
    { text: '意识上传', slotX: 20, slotY: 75 },
    { text: '2031.9.17', slotX: 20, slotY: 120 },
    { text: '实验体', slotX: 150, slotY: 30 },
    { text: '永生计划', slotX: 150, slotY: 75 },
  ];
  panel.innerHTML = `
    <div class="mg-title">残 破 报 纸</div>
    <div class="mg-desc">地上散落着撕碎的报纸，拖动碎片到正确位置还原信息。</div>
    <div class="mg-puzzle-zone" id="mg-puzzle-zone"></div>
    <div class="mg-hint" id="mg-puzzle-hint">将碎片拖到虚线框中</div>
  `;
  overlay._addSkip();
  const zone = panel.querySelector('#mg-puzzle-zone');
  let filled = 0;

  // Create slots
  fragments.forEach((f, i) => {
    const slot = document.createElement('div');
    slot.className = 'mg-puzzle-slot';
    slot.style.left = f.slotX + 'px'; slot.style.top = f.slotY + 'px';
    slot.textContent = f.text;
    slot.dataset.idx = i;
    zone.appendChild(slot);
  });

  // Create draggable pieces at random positions
  const shuffled = [...fragments].sort(() => Math.random() - 0.5);
  shuffled.forEach((f, i) => {
    const piece = document.createElement('div');
    piece.className = 'mg-puzzle-piece';
    piece.textContent = f.text;
    piece.dataset.idx = fragments.indexOf(f);
    // Random start position on right side
    piece.style.left = (180 + Math.random() * 60) + 'px';
    piece.style.top = (15 + i * 38) + 'px';
    zone.appendChild(piece);

    let startX, startY, origLeft, origTop;
    function onStart(e) {
      e.preventDefault();
      const touch = e.touches ? e.touches[0] : e;
      const rect = piece.getBoundingClientRect();
      startX = touch.clientX; startY = touch.clientY;
      origLeft = piece.offsetLeft; origTop = piece.offsetTop;
      piece.classList.add('mg-dragging');
    }
    function onMove(e) {
      if (!piece.classList.contains('mg-dragging')) return;
      e.preventDefault();
      const touch = e.touches ? e.touches[0] : e;
      const dx = touch.clientX - startX, dy = touch.clientY - startY;
      piece.style.left = (origLeft + dx) + 'px';
      piece.style.top = (origTop + dy) + 'px';
    }
    function onEnd() {
      if (!piece.classList.contains('mg-dragging')) return;
      piece.classList.remove('mg-dragging');
      // Check if near correct slot
      const idx = parseInt(piece.dataset.idx);
      const slot = zone.querySelector(`.mg-puzzle-slot[data-idx="${idx}"]`);
      const pRect = piece.getBoundingClientRect();
      const sRect = slot.getBoundingClientRect();
      const dist = Math.hypot(pRect.left - sRect.left, pRect.top - sRect.top);
      if (dist < 40) {
        piece.style.left = slot.style.left;
        piece.style.top = slot.style.top;
        piece.style.pointerEvents = 'none';
        piece.style.opacity = '0';
        slot.classList.add('mg-filled');
        filled++;
        if (filled >= fragments.length) {
          panel.querySelector('#mg-puzzle-hint').textContent = '报纸内容还原完成！';
          panel.querySelector('#mg-puzzle-hint').style.color = '#90e8a0';
          applyStat({ reason: 5 });
          removeMiniGame(overlay, 1200);
          setTimeout(onComplete, 1400);
        }
      }
    }
    piece.addEventListener('mousedown', onStart);
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', onEnd);
    piece.addEventListener('touchstart', onStart, { passive: false });
    document.addEventListener('touchmove', onMove, { passive: false });
    document.addEventListener('touchend', onEnd);
  });
}

// --- 电梯长按（信号塔场景） ---
function startElevatorHold(targetFloor, onSuccess, onFail) {
  const { overlay, panel } = createMiniGameOverlay(onFail);
  panel.innerHTML = `
    <div class="mg-title">电 梯 上 升</div>
    <div class="mg-desc">电梯开始运行，但系统不断尝试中断。<br>按住按钮保持电梯运行！</div>
    <div class="mg-hold-floor" id="mg-hold-floor">1F</div>
    <div class="mg-qte-progress"><div class="mg-qte-progress-fill" id="mg-hold-fill" style="width:0%"></div></div>
    <div class="mg-hold-zone" id="mg-hold-zone">
      <button class="mg-hold-btn" id="mg-hold-btn">按住</button>
    </div>
    <div class="mg-hint" id="mg-hold-hint">持续按住按钮，不要松手！</div>
  `;
  overlay._addSkip();
  const btn = panel.querySelector('#mg-hold-btn');
  const floorEl = panel.querySelector('#mg-hold-floor');
  const fillEl = panel.querySelector('#mg-hold-fill');
  const hintEl = panel.querySelector('#mg-hold-hint');
  const holdZone = panel.querySelector('#mg-hold-zone');

  let pressing = false;
  let progress = 0;
  let ended = false;
  let failCount = 0;
  const maxFails = 3;

  function startPress() { if (ended) return; pressing = true; btn.classList.add('mg-pressing'); btn.textContent = '保持'; }
  function endPress() { if (ended) return; pressing = false; btn.classList.remove('mg-pressing'); btn.textContent = '按住'; }

  btn.addEventListener('mousedown', startPress);
  btn.addEventListener('touchstart', (e) => { e.preventDefault(); startPress(); }, { passive: false });
  document.addEventListener('mouseup', endPress);
  document.addEventListener('touchend', endPress);

  // Glitch interruptions
  const glitchMsgs = ['警告：未授权访问', '系统异常', '意识不稳定', '回收程序启动中', '连接中断'];
  let glitchTimer = setInterval(() => {
    if (ended) return;
    const glitch = document.createElement('div');
    glitch.className = 'mg-hold-glitch';
    glitch.textContent = glitchMsgs[Math.floor(Math.random() * glitchMsgs.length)];
    holdZone.appendChild(glitch);
    setTimeout(() => glitch.remove(), 800);
  }, 2000);

  let hasStarted = false; // 玩家是否按过按钮
  let wasAboveZero = false; // 进度是否曾经上升过

  let gameLoop = setInterval(() => {
    if (ended) { clearInterval(gameLoop); clearInterval(glitchTimer); return; }
    if (pressing) {
      hasStarted = true;
      wasAboveZero = true;
      progress = Math.min(100, progress + 1.2);
    } else if (hasStarted) {
      // 只有玩家按过之后松手才扣进度
      progress = Math.max(0, progress - 2.5);
      // 进度从高处跌回0才算一次失败
      if (progress <= 0 && wasAboveZero) {
        wasAboveZero = false;
        failCount++;
        if (failCount >= maxFails) {
          ended = true;
          btn.classList.add('mg-fail'); btn.textContent = '失败';
          hintEl.textContent = '电梯停止了……你被迫爬楼梯上去';
          hintEl.style.color = '#f0a060';
          clearInterval(gameLoop); clearInterval(glitchTimer);
          removeMiniGame(overlay, 1500);
          setTimeout(onFail, 1700);
          return;
        }
      }
    }
    const floor = Math.floor(progress / 100 * targetFloor);
    floorEl.textContent = Math.max(1, floor) + 'F';
    fillEl.style.width = progress + '%';
    if (progress >= 100) {
      ended = true;
      floorEl.textContent = targetFloor + 'F';
      btn.textContent = '到达';
      btn.classList.remove('mg-pressing');
      hintEl.textContent = '成功到达顶层！';
      hintEl.style.color = '#90e8a0';
      applyStat({ courage: 5 });
      clearInterval(gameLoop); clearInterval(glitchTimer);
      removeMiniGame(overlay, 1200);
      setTimeout(onSuccess, 1400);
    }
  }, 50);
}

// --- 打字挑战 / 黑客入侵（真相场景） ---
function startHackTyping(commands, onSuccess, onFail) {
  const { overlay, panel } = createMiniGameOverlay(onFail || onSuccess);
  panel.innerHTML = `
    <div class="mg-title">系 统 入 侵</div>
    <div class="mg-desc">管理员后门已找到，快速输入指令序列来获取权限！</div>
    <div class="mg-type-display" id="mg-type-display"></div>
    <input class="mg-type-input" id="mg-type-input" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" placeholder="在此输入指令...">
    <div class="mg-type-progress"><div class="mg-type-progress-fill" id="mg-type-fill" style="width:0%"></div></div>
    <div class="mg-hint" id="mg-type-hint">逐字输入显示的指令</div>
  `;
  overlay._addSkip();
  const display = panel.querySelector('#mg-type-display');
  const input = panel.querySelector('#mg-type-input');
  const fillEl = panel.querySelector('#mg-type-fill');
  const hintEl = panel.querySelector('#mg-type-hint');

  let cmdIdx = 0;
  let charPos = 0;
  let totalChars = commands.reduce((s, c) => s + c.length, 0);
  let doneChars = 0;

  function renderDisplay() {
    const cmd = commands[cmdIdx];
    const typed = cmd.substring(0, charPos);
    const cursorChar = cmd[charPos] || '';
    const untyped = cmd.substring(charPos + 1);
    display.innerHTML = `<span style="color:rgba(100,200,120,0.6)">$ </span><span class="mg-typed">${typed}</span><span class="mg-cursor-char">${cursorChar}</span><span class="mg-untyped">${untyped}</span>`;
  }
  renderDisplay();
  setTimeout(() => input.focus(), 300);

  input.addEventListener('input', () => {
    const val = input.value;
    const cmd = commands[cmdIdx];
    const expected = cmd[charPos];
    if (val && val[val.length - 1] === expected) {
      charPos++;
      doneChars++;
      fillEl.style.width = (doneChars / totalChars * 100) + '%';
      input.value = '';
      if (charPos >= cmd.length) {
        cmdIdx++;
        charPos = 0;
        if (cmdIdx >= commands.length) {
          display.innerHTML = `<span style="color:#90e8a0">ACCESS GRANTED — 权限已获取</span>`;
          input.style.display = 'none';
          hintEl.textContent = '入侵成功！';
          hintEl.style.color = '#90e8a0';
          applyStat({ reason: 8 });
          removeMiniGame(overlay, 1200);
          setTimeout(onSuccess, 1400);
          return;
        }
      }
      renderDisplay();
    } else {
      input.value = '';
      // Flash red briefly
      input.style.borderColor = 'rgba(220,80,80,0.7)';
      setTimeout(() => { input.style.borderColor = ''; }, 200);
    }
  });
}

// --- 推门连点（逃离场景） ---
function startDoorMash(targetHits, timeLimit, onSuccess, onFail) {
  const { overlay, panel } = createMiniGameOverlay(onFail);
  panel.innerHTML = `
    <div class="mg-title">推 开 铁 门</div>
    <div class="mg-desc">一扇沉重的铁门挡在面前。<br>用尽全力推开它！</div>
    <div class="mg-qte-timer" id="mg-mash-timer">${(timeLimit / 1000).toFixed(1)}</div>
    <div class="mg-mash-bar"><div class="mg-mash-bar-fill" id="mg-mash-fill" style="width:0%"></div></div>
    <div class="mg-mash-zone">
      <button class="mg-mash-btn" id="mg-mash-btn">&#128074;</button>
    </div>
    <div class="mg-mash-crack" id="mg-mash-crack"></div>
    <div class="mg-hint" id="mg-mash-hint">疯狂点击！</div>
  `;
  overlay._addSkip();
  const btn = panel.querySelector('#mg-mash-btn');
  const fillEl = panel.querySelector('#mg-mash-fill');
  const timerEl = panel.querySelector('#mg-mash-timer');
  const crackEl = panel.querySelector('#mg-mash-crack');
  const hintEl = panel.querySelector('#mg-mash-hint');

  let hits = 0;
  let ended = false;
  const startTime = Date.now();
  const crackStages = ['', '咔……', '嘎吱……', '裂缝出现了！', '门在松动！', '快了！'];

  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    if (ended) return;
    hits++;
    const pct = Math.min(100, hits / targetHits * 100);
    fillEl.style.width = pct + '%';
    const stage = Math.min(crackStages.length - 1, Math.floor(pct / 20));
    crackEl.textContent = crackStages[stage];
    if (hits >= targetHits) {
      ended = true;
      hintEl.textContent = '门被推开了！';
      hintEl.style.color = '#90e8a0';
      crackEl.textContent = '轰——！';
      crackEl.style.color = '#f0e0a0';
      applyStat({ courage: 8 });
      removeMiniGame(overlay, 1000);
      setTimeout(onSuccess, 1200);
    }
  });

  let timerInterval = setInterval(() => {
    if (ended) { clearInterval(timerInterval); return; }
    const elapsed = Date.now() - startTime;
    const remaining = Math.max(0, timeLimit - elapsed);
    timerEl.textContent = (remaining / 1000).toFixed(1);
    if (remaining <= 0) {
      ended = true;
      clearInterval(timerInterval);
      hintEl.textContent = '力气不够……但门开了一条缝';
      hintEl.style.color = '#f0a060';
      crackEl.textContent = '你侧身挤了过去';
      removeMiniGame(overlay, 1500);
      setTimeout(onFail, 1700);
    }
  }, 100);
}


